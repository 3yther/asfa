ANTHROPIC_API_KEY=your_anthropic_api_key
NEWS_API_KEY=your_newsapi_key
WEATHER_API_KEY=your_openweathermap_key
# USDA FoodData Central (nutrition text search). Optional: falls back to the
# shared DEMO_KEY, which is rate-limited (~30/hr, 50/day per IP). Get a free
# real key at https://fdc.nal.usda.gov/api-key-signup for production.
FDC_API_KEY=DEMO_KEY
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret
# Must EXACTLY match an Authorized redirect URI in the Google OAuth client
# (scheme, host, path — no trailing slash).
# Local: http://localhost:5000/auth/google/callback
# Prod:  https://asfa-production.up.railway.app/auth/google/callback
GOOGLE_REDIRECT_URI=http://localhost:5000/auth/google/callback

# ── Spotify (auto-resume playback on load) ───────────────────────────────────
# Create an app at https://developer.spotify.com/dashboard and add the redirect
# URI there EXACTLY (scheme, host, path — no trailing slash).
# Local: http://localhost:5000/auth/spotify/callback
# Prod:  https://asfa-production.up.railway.app/auth/spotify/callback
SPOTIFY_CLIENT_ID=optional_spotify_client_id
SPOTIFY_CLIENT_SECRET=optional_spotify_client_secret
SPOTIFY_REDIRECT_URI=http://localhost:5000/auth/spotify/callback

TELEGRAM_BOT_TOKEN=optional_telegram_bot_token
TELEGRAM_CHAT_ID=optional_your_telegram_chat_id
DATABASE_URL=optional_postgresql_url_for_production
SECRET_KEY=change_this_to_a_random_secret_key
# Shared passphrase that gates the whole dashboard (personal Gmail/Calendar/
# finance data). REQUIRED — the app stays locked until this is set.
APP_PASSWORD=set_a_strong_passphrase

# ── Production DB backup (Postgres → private GitHub repo) ─────────────────────
# Daily 03:00 Europe/London dump pushed via the GitHub Contents API. No-op on
# local SQLite. Token needs contents:write on the private backups repo.
BACKUP_GITHUB_TOKEN=optional_github_pat_with_contents_write
BACKUP_REPO=optional_owner/asfa-backups

# Obsidian sync — daily markdown logs are written here (local filesystem only,
# i.e. when ASFA runs on your Mac). Defaults to ~/Obsidian/ASFA-Logs.
OBSIDIAN_VAULT_PATH=optional_path_to_your_obsidian_vault_folder

# ── Proactive alerts & daily summary (all optional) ──────────────────────────
# Discord: paste a channel webhook URL to receive alerts there.
DISCORD_WEBHOOK_URL=optional_discord_webhook_url
# Email: SMTP for the auto 21:00 UTC daily summary. Leave blank to skip email
# (summary still goes to Telegram + the in-app bell).
SMTP_HOST=optional_smtp_host
SMTP_PORT=587
SMTP_USER=optional_smtp_username
SMTP_PASSWORD=optional_smtp_password_or_app_password
SUMMARY_EMAIL_TO=optional_your_email@example.com
SUMMARY_EMAIL_FROM=optional_from_address_defaults_to_smtp_user

# ── Workout plan baselines (/gym/plan) — all optional ────────────────────────
# Your bodyweight, lift numbers and health goals are biometric/medical data and
# this repo is public, so they are read from here rather than committed to
# source. Leave any of them blank and the plan page still renders — it just
# shows nothing personal and reports the baseline as not configured.
#
# Bodyweight goal, in kg.
PLAN_BASELINE_KG=optional_starting_bodyweight_kg
PLAN_TARGET_KG=optional_goal_bodyweight_kg
# Main-lift progression roadmap, in kg. START is where the roadmap begins,
# TARGET is the September aim, REACH is the stretch goal.
PLAN_BENCH_START_KG=optional_roadmap_start_kg
PLAN_BENCH_START_REPS=optional_reps_at_start
PLAN_BENCH_TARGET_KG=optional_target_kg
PLAN_BENCH_TARGET_REPS=optional_reps_at_target
PLAN_BENCH_REACH_KG=optional_stretch_goal_kg
PLAN_BENCH_GOAL_KG=optional_realistic_pr_goal_kg
# Progression cadence, used to phrase the roadmap note (e.g. "+5kg per 2 weeks").
PLAN_BENCH_STEP_KG=optional_kg_per_step
PLAN_BENCH_STEP_WEEKS=optional_weeks_per_step
# Anything private that has no number attached (health markers, appearance).
# JSON list of {"name", "notes"}. Kept out of source entirely.
PLAN_PRIVATE_GOALS=[{"name":"Example goal","notes":"Example note"}]
