ANTHROPIC_API_KEY=your_anthropic_api_key
NEWS_API_KEY=your_newsapi_key
WEATHER_API_KEY=your_openweathermap_key
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret
# Must EXACTLY match an Authorized redirect URI in the Google OAuth client
# (scheme, host, path — no trailing slash).
# Local: http://localhost:5000/auth/google/callback
# Prod:  https://asfa-production.up.railway.app/auth/google/callback
GOOGLE_REDIRECT_URI=http://localhost:5000/auth/google/callback

# ── Spotify (auto-resume playback on load) ───────────────────────────────────
# Create an app at https://developer.spotify.com/dashboard and add the redirect
# URI there EXACTLY (scheme, host, path — no trailing slash).
# Local: http://localhost:5000/auth/spotify/callback
# Prod:  https://asfa-production.up.railway.app/auth/spotify/callback
SPOTIFY_CLIENT_ID=optional_spotify_client_id
SPOTIFY_CLIENT_SECRET=optional_spotify_client_secret
SPOTIFY_REDIRECT_URI=http://localhost:5000/auth/spotify/callback

TELEGRAM_BOT_TOKEN=optional_telegram_bot_token
TELEGRAM_CHAT_ID=optional_your_telegram_chat_id
DATABASE_URL=optional_postgresql_url_for_production
SECRET_KEY=change_this_to_a_random_secret_key

# Obsidian sync — daily markdown logs are written here (local filesystem only,
# i.e. when ASFA runs on your Mac). Defaults to ~/Obsidian/ASFA-Logs.
OBSIDIAN_VAULT_PATH=optional_path_to_your_obsidian_vault_folder

# ── Proactive alerts & daily summary (all optional) ──────────────────────────
# Discord: paste a channel webhook URL to receive alerts there.
DISCORD_WEBHOOK_URL=optional_discord_webhook_url
# Email: SMTP for the auto 21:00 UTC daily summary. Leave blank to skip email
# (summary still goes to Telegram + the in-app bell).
SMTP_HOST=optional_smtp_host
SMTP_PORT=587
SMTP_USER=optional_smtp_username
SMTP_PASSWORD=optional_smtp_password_or_app_password
SUMMARY_EMAIL_TO=optional_your_email@example.com
SUMMARY_EMAIL_FROM=optional_from_address_defaults_to_smtp_user
